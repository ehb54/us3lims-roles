#%Module 1.0
#
#  ultrascan/build module for use with 'environment-modules' package:
#

proc ModulesHelp { } {
   puts stderr "This module switches ultrascan to the one in your home directory\nUse for building and running\n"
}

module-whatis "This module switches ultrascan to the one in your home directory\nUse for building and running\n"


# Only allow one ultrascan/* module to be loaded at a time
conflict ultrascan

# Define prefix so PATH and MANPATH can be updated.

setenv        US_GUI        $::env(HOME)/ultrascan3_qt6
setenv        ULTRASCAN     $::env(HOME)/ultrascan3_qt6
setenv        QTDIR         /opt/qt-{{ qt_version }}
setenv        QWTDIR        /opt/qt-{{ qt_version }}-qwt-{{ qwt_version }}
setenv        US3DIR	    $::env(HOME)/ultrascan3_qt6
setenv        QTBIN	    /opt/qt-{{ qt_version }}/bin
setenv        QTLIB	    /opt/qt-{{ qt_version }}/lib
setenv        QTINC	    /opt/qt-{{ qt_version }}/include
setenv        US3BIN	    $::env(HOME)/ultrascan3_qt6/bin
setenv        US3LIB	    $::env(HOME)/ultrascan3_qt6/lib
setenv        us3	    $::env(HOME)/ultrascan3_qt6

prepend-path  PATH          $::env(HOME)/ultrascan3_qt6/bin:/opt/qt-{{ qt_version }}/bin:/opt/qt-{{ qt_version }}/libexec
prepend-path  LD_LIBRARY_PATH $::env(HOME)/ultrascan3_qt6/lib:/opt/qt-{{ qt_version }}/lib:/opt/qt-{{ qt_version }}-qwt-{{ qwt_version }}/lib

# gcc-toolset-{{ gcc_toolset_version }} addendum
prepend-path    INFOPATH        /opt/rh/gcc-toolset-{{ gcc_toolset_version }}/root/usr/share/info
prepend-path    LD_LIBRARY_PATH /opt/rh/gcc-toolset-{{ gcc_toolset_version }}/root/usr/lib64:/opt/rh/gcc-toolset-{{ gcc_toolset_version }}/root/usr/lib:/opt/rh/gcc-toolset-{{ gcc_toolset_version }}/root/usr/lib64/dyninst:/opt/rh/gcc-toolset-{{ gcc_toolset_version }}/root/usr/lib/dyninst
prepend-path    MANPATH /opt/rh/gcc-toolset-{{ gcc_toolset_version }}/root/usr/share/man
prepend-path    PATH    /opt/rh/gcc-toolset-{{ gcc_toolset_version }}/root/usr/bin
prepend-path    PKG_CONFIG_PATH /opt/rh/gcc-toolset-{{ gcc_toolset_version }}/root/usr/lib64/pkgconfig
setenv          PCP_DIR /opt/rh/gcc-toolset-{{ gcc_toolset_version }}/root
